// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Postgres mirror of Shopify catalog + supplier data ────────────────────
// Metafields/metaobjects in Shopify remain the source of truth. These models
// are a read-cache populated by a nightly bulk-op sync (app/services/sync.server.js)
// and kept warm by webhooks + write-through on saves. A failed mirror write is
// logged and non-fatal — the nightly reconcile heals any drift.

model Supplier {
  id             String   @id // metaobject GID
  shop           String
  supplierId     String // business key stored in the "supplier_id" metaobject field
  name           String
  specializedMfg Boolean  @default(false)
  contactName    String?
  contactName2   String?
  address        String?
  address2       String?
  city           String?
  state          String?
  zip            String?
  country        String?
  phone1         String?
  phone2         String?
  email1         String?
  email2         String?
  website        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, supplierId])
  @@index([shop])
}

model Product {
  id        String   @id // product GID
  shop      String
  title     String
  status    String
  vendor    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants Variant[]

  @@index([shop, status])
}

model Variant {
  id                String   @id // variant GID
  shop              String
  productId         String
  sku               String?
  title             String?
  inventoryQuantity Int      @default(0)
  inventoryItemId   String? // inventory item GID; needed for inventory webhooks + PO receiving
  supplierDataRaw   Json? // verbatim mirror of the inventory.supplier_data metafield value
  sourcingType      String? // "nos" | "repro" | "resale" — mirror of inventory.sourcing_type metafield
  reproRunSize      Int? // mirror of inventory.repro_settings.run_size
  reproMoq          Int? // mirror of inventory.repro_settings.moq
  reproRunCost      Float? // mirror of inventory.repro_settings.run_cost
  reproToolingNotes String? // mirror of inventory.repro_settings.tooling_notes
  velocity30        Float? // avg units/day, trailing 30 days — from VariantSalesDay via recomputeVelocities
  velocity90        Float? // avg units/day, trailing 90 days
  velocity365       Float? // avg units/day, trailing 365 days
  velocityUpdatedAt DateTime? // last time recomputeVelocities touched this row
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sources   VariantSource[]
  salesDays VariantSalesDay[]

  @@index([shop, sku])
  @@index([shop, productId])
  @@index([shop, sourcingType])
}

// Daily sales aggregate per variant, built by the orders bulk-op backfill
// (app/services/demand.server.js) and kept warm by the orders/create webhook.
// Raw order/line-item data isn't stored — only the day-level rollup that
// recomputeVelocities reads to derive Variant.velocity30/90/365.
model VariantSalesDay {
  id        String   @id @default(cuid())
  shop      String
  variantId String
  date      DateTime @db.Date
  qty       Int      @default(0)
  revenue   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([shop, variantId, date])
  @@index([shop, date])
}

// One row per entry in a variant's supplier_data array. supplierId is a soft
// reference to Supplier.supplierId (the business key stored in the metafield
// JSON, not Supplier's GID primary key) — kept as a plain indexed column
// rather than a DB-level FK since sync/webhook ordering can't guarantee the
// referenced supplier metaobject has already been mirrored.
model VariantSource {
  id            String   @id @default(cuid())
  shop          String
  variantId     String
  supplierId    String?
  mpn           String?
  isPrimary     Boolean  @default(false)
  leadTime      Int?
  threshold     Int?
  dailyDemand   Float?
  lastOrderDate String?
  lastOrderCpu  Float?
  lastOrderQty  Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([shop, variantId])
  @@index([shop, supplierId])
}

model SyncState {
  id                String    @id @default(cuid())
  shop              String    @unique
  bulkOperationId   String?
  bulkStatus        String?
  bulkOperationType String? // "catalog" | "orders" — which query the in-flight/last bulkOperationId ran, since only one bulk op may run per shop at a time and the finish webhook doesn't say which
  lastFullSyncAt    DateTime?
  lastOrdersSyncAt  DateTime? // last time the orders backfill bulk op completed
  locationId        String? // primary location GID, captured during sync for future PO receiving
  error             String?
  updatedAt         DateTime  @updatedAt
}

// Draft/sent/received purchase orders. supplierId is a soft reference to
// Supplier.supplierId (business key), same convention as VariantSource,
// since a PO can be drafted for a supplier before its metaobject syncs.
model PurchaseOrder {
  id         String    @id @default(cuid())
  shop       String
  number     Int // sequential per shop, assigned on create
  supplierId String
  status     String    @default("DRAFT") // DRAFT|SENT|PARTIAL|RECEIVED|CANCELLED
  notes      String?
  sentAt     DateTime?
  receivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lineItems POLineItem[]

  @@unique([shop, number])
  @@index([shop, status])
  @@index([shop, supplierId])
}

model POLineItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  variantId       String // variant GID — not FK'd to Variant since a PO should survive a variant mirror gap
  sku             String?
  mpn             String?
  qtyOrdered      Int
  qtyReceived     Int      @default(0)
  unitCost        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([variantId])
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
